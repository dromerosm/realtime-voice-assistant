# App
PORT=3000
APP_PORT=3001

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_INSTRUCTIONS=You are a concise real-time voice assistant. Remember user details during the current session.
OPENAI_REALTIME_CLIENT_SECRET_TTL_SECONDS=120
OPENAI_REALTIME_TOKEN_RATE_LIMIT_WINDOW_MS=60000
OPENAI_REALTIME_TOKEN_RATE_LIMIT_MAX_REQUESTS=5
# If you change APP_PORT locally, update this origin too.
OPENAI_REALTIME_ALLOWED_ORIGINS=http://localhost:3001

# Persistent memory
OPENAI_MEMORY_ENABLED=true
OPENAI_MEMORY_MODEL=gpt-5-mini
MEMORY_DB_PATH=/data/memory.sqlite
MEMORY_ADMIN_TOKEN=change_me_before_production
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_SESSION_SECRET=

# Optional Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
