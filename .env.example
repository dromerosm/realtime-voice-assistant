# Secrets only.
# Non-secret runtime settings live in app.config.json.
# Start with OPENAI_API_KEY for local use. The rest are optional depending on features enabled.

# Required for any realtime session
OPENAI_API_KEY=

# Required only if appLogin.enabled=true
APP_LOGIN_PASSWORD_HASH=
APP_SESSION_SECRET=

# Required only if you want admin session / memory reset actions
MEMORY_ADMIN_TOKEN=
ADMIN_SESSION_SECRET=

# Required only if you configure Turnstile in app.config.json
TURNSTILE_SECRET_KEY=
